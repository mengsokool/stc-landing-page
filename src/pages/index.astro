---
import Layout from "@/layouts/main.astro"
import { FlickeringGrid } from "@/components/ui/flickering-grid"
import { cn } from "@/lib/utils"
import { portalConfig } from "@/portal.config"
import {
  IconBriefcase,
  IconBuilding,
  IconBuildingFactory,
  IconCalendarEvent,
  IconClockCheck,
  IconExternalLink,
  IconPrinter,
  IconQrcode,
  IconSchool,
  IconShieldCheck,
  IconUserPlus,
} from "@tabler/icons-react"

interface ServiceLink {
  name: string
  url: string
  icon: any
}

const mainLinks: ServiceLink[] = [
  {
    name: "บริการนักเรียน",
    url: portalConfig.endpoints.student,
    icon: IconSchool,
  },
  {
    name: "บริการครู",
    url: portalConfig.endpoints.teacher,
    icon: IconBriefcase,
  },
  {
    name: "บริการสถานประกอบการ",
    url: portalConfig.endpoints.workplace,
    icon: IconBuildingFactory,
  },
]

const featuredLinks: ServiceLink[] = [
  {
    name: "สมัครเรียน",
    url: portalConfig.endpoints.admission,
    icon: IconUserPlus,
  },
  ...mainLinks,
]

const staffLinks: ServiceLink[] = [
  {
    name: "งานปกครอง",
    url: portalConfig.endpoints.discipline,
    icon: IconShieldCheck,
  },
  {
    name: "งานกิจกรรม",
    url: portalConfig.endpoints.activity,
    icon: IconCalendarEvent,
  },
  {
    name: "ลงเวลาปฏิบัติงาน",
    url: portalConfig.endpoints.attendance,
    icon: IconClockCheck,
  },
  {
    name: "ขออนุญาตใช้อาคาร",
    url: portalConfig.endpoints.facility,
    icon: IconBuilding,
  },
]

const utilityLinks: ServiceLink[] = [
  {
    name: "ขอ QR Code เช็คชื่อ",
    url: portalConfig.endpoints.qrGuidance,
    icon: IconQrcode,
  },
]

const institutionLabel =
  portalConfig.institutionName || "ระบบบริการสถานศึกษาออนไลน์"
---

<Layout>
  <main class="min-h-screen bg-background text-foreground">
    <section
      class="relative overflow-hidden bg-primary py-8 text-primary-foreground md:py-0"
    >
      <FlickeringGrid
        client:load
        className="absolute inset-0 z-0 [mask-image:linear-gradient(to_bottom,white_72%,rgba(255,255,255,0.55)_84%,transparent)]"
        squareSize={5}
        gridGap={8}
        color="#FF1111"
        maxOpacity={0.24}
        flickerChance={0.28}
      />
      <div
        class="absolute inset-x-0 bottom-0 z-0 h-48 bg-linear-to-t from-background via-background/55 to-transparent"
      >
      </div>
      <div
        class="absolute inset-x-0 bottom-0 z-0 h-28 bg-linear-to-t from-background/80 to-transparent blur-md"
      >
      </div>

      <div
        class="relative z-10 mx-auto grid w-full max-w-6xl gap-8 px-4 pt-16 pb-32 md:grid-cols-[minmax(0,1fr)_320px] md:px-8 md:pt-16 md:pb-32"
      >
        <div class="relative z-10">
          <p class="text-base font-semibold text-primary-foreground/80">
            ยินดีต้อนรับสู่
          </p>
          <h1
            class="mt-1 text-6xl leading-none font-semibold tracking-normal md:text-7xl"
          >
            {portalConfig.productName}
          </h1>
          <p
            class="mt-4 hidden max-w-xl text-lg leading-8 text-primary-foreground/80 md:block"
          >
            {portalConfig.description}
          </p>
        </div>

        <div
          class="pointer-events-none absolute right-0 -bottom-16 z-0 md:relative md:right-auto md:bottom-auto"
        >
          <img
            src={portalConfig.mascot}
            alt=""
            class="h-64 w-auto object-contain drop-shadow-2xl md:absolute md:top-0 md:right-0 md:h-72"
          />
        </div>
      </div>
    </section>

    <div
      id="services"
      class="relative z-20 mx-auto w-full max-w-6xl px-4 pb-16 md:px-8"
    >
      <section class="-mt-16 grid grid-cols-2 gap-4 lg:grid-cols-4">
        {
          featuredLinks.map((link) => {
            const Icon = link.icon
            return (
              <a
                href={link.url}
                class="group flex flex-col gap-8 rounded-md border bg-card p-4 shadow-sm transition-all hover:shadow-md focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
              >
                <div class="flex items-center justify-between gap-4">
                  <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-primary-foreground">
                    <Icon size={28} stroke={1.7} />
                  </div>
                  <IconExternalLink
                    size={18}
                    className="text-muted-foreground/30 transition-colors group-hover:text-primary/70"
                    stroke={1.8}
                  />
                </div>
                <div>
                  <h2 class="text-lg font-semibold text-card-foreground md:text-xl">
                    {link.name}
                  </h2>
                </div>
              </a>
            )
          })
        }
      </section>

      <section class="mt-16">
        <div class="mb-4 flex items-end justify-between gap-4">
          <div>
            <p class="text-sm font-bold text-primary">บริการทั่วไป</p>
            <h2 class="mt-1 text-2xl font-bold">เครื่องมือเพิ่มเติม</h2>
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {
            utilityLinks.map((link) => {
              const Icon = link.icon
              return (
                <a
                  href={link.url}
                  class="group flex items-center gap-4 rounded-lg border border-transparent bg-muted/40 p-4 transition-all hover:border-border hover:bg-card hover:shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
                >
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-muted text-muted-foreground transition-colors group-hover:bg-primary/10 group-hover:text-primary">
                    <Icon size={22} stroke={1.7} />
                  </div>
                  <h3 class="flex-1 text-sm font-semibold text-card-foreground">
                    {link.name}
                  </h3>
                  <IconExternalLink
                    size={16}
                    className="text-muted-foreground/30 transition-colors group-hover:text-primary/70"
                    stroke={1.8}
                  />
                </a>
              )
            })
          }
        </div>
      </section>

      <section class="mt-16">
        <div class="mb-4 flex items-end justify-between gap-4">
          <div>
            <p class="text-sm font-bold text-muted-foreground">สำหรับบุคลากร</p>
            <h2 class="mt-1 text-2xl font-bold">ระบบงานภายใน</h2>
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {
            staffLinks.map((link) => {
              const Icon = link.icon
              return (
                <a
                  href={link.url}
                  class="group flex items-center gap-4 rounded-lg border border-transparent bg-muted/40 p-4 transition-all hover:border-border hover:bg-card hover:shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
                >
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-muted text-muted-foreground transition-colors group-hover:bg-primary/10 group-hover:text-primary">
                    <Icon size={22} stroke={1.7} />
                  </div>
                  <h3 class="flex-1 text-sm font-semibold text-card-foreground">
                    {link.name}
                  </h3>
                  <IconExternalLink
                    size={16}
                    className="text-muted-foreground/30 transition-colors group-hover:text-primary/70"
                    stroke={1.8}
                  />
                </a>
              )
            })
          }
        </div>
      </section>
    </div>
  </main>
</Layout>
