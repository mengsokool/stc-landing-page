---
import Layout from "@/layouts/main.astro"
import { cn } from "@/lib/utils"
import { portalConfig } from "@/portal.config"
import {
  IconBriefcase,
  IconBuilding,
  IconBuildingFactory,
  IconCalendarEvent,
  IconClockCheck,
  IconExternalLink,
  IconPrinter,
  IconQrcode,
  IconSchool,
  IconShieldCheck,
  IconUserPlus,
} from "@tabler/icons-react"

interface ServiceLink {
  name: string
  url: string
  icon?: any
  image?: string
  highlight?: boolean
  colorClasses?: {
    iconBg: string
    iconText: string
    hoverIconBg: string
    hoverIconText: string
    cardBorderHover: string
  }
}

const mainLinks: ServiceLink[] = [
  {
    name: "บริการนักเรียน",
    url: portalConfig.endpoints.student,
    icon: IconSchool,
    colorClasses: {
      iconBg: "bg-blue-100 dark:bg-blue-900/40",
      iconText: "text-blue-600 dark:text-blue-400",
      hoverIconBg: "group-hover:bg-blue-600 dark:group-hover:bg-blue-500",
      hoverIconText: "group-hover:text-white",
      cardBorderHover: "hover:border-blue-300 dark:hover:border-blue-700/50",
    },
  },
  {
    name: "บริการครู",
    url: portalConfig.endpoints.teacher,
    icon: IconBriefcase,
    colorClasses: {
      iconBg: "bg-purple-100 dark:bg-purple-900/40",
      iconText: "text-purple-600 dark:text-purple-400",
      hoverIconBg: "group-hover:bg-purple-600 dark:group-hover:bg-purple-500",
      hoverIconText: "group-hover:text-white",
      cardBorderHover: "hover:border-purple-300 dark:hover:border-purple-700/50",
    },
  },
  {
    name: "สถานประกอบการ",
    url: portalConfig.endpoints.workplace,
    icon: IconBuildingFactory,
    colorClasses: {
      iconBg: "bg-amber-100 dark:bg-amber-900/40",
      iconText: "text-amber-600 dark:text-amber-400",
      hoverIconBg: "group-hover:bg-amber-500 dark:group-hover:bg-amber-400",
      hoverIconText: "group-hover:text-white dark:group-hover:text-amber-950",
      cardBorderHover: "hover:border-amber-300 dark:hover:border-amber-700/50",
    },
  },
]

const featuredLinks: ServiceLink[] = [
  {
    name: "สมัครเรียน",
    url: portalConfig.endpoints.admission,
    icon: IconUserPlus,
    colorClasses: {
      iconBg: "bg-emerald-100 dark:bg-emerald-900/40",
      iconText: "text-emerald-600 dark:text-emerald-400",
      hoverIconBg: "group-hover:bg-emerald-500 dark:group-hover:bg-emerald-400",
      hoverIconText: "group-hover:text-white dark:group-hover:text-emerald-950",
      cardBorderHover: "hover:border-emerald-300 dark:hover:border-emerald-700/50",
    },
  },
  ...mainLinks,
]

const staffLinks: ServiceLink[] = [
  {
    name: "งานปกครอง",
    url: portalConfig.endpoints.discipline,
    icon: IconShieldCheck,
    colorClasses: {
      iconBg: "bg-rose-100 dark:bg-rose-900/40",
      iconText: "text-rose-600 dark:text-rose-400",
      hoverIconBg: "group-hover:bg-rose-500 dark:group-hover:bg-rose-500",
      hoverIconText: "group-hover:text-white",
      cardBorderHover: "hover:border-rose-300 dark:hover:border-rose-700/50",
    },
  },
  {
    name: "งานกิจกรรม",
    url: portalConfig.endpoints.activity,
    icon: IconCalendarEvent,
    colorClasses: {
      iconBg: "bg-teal-100 dark:bg-teal-900/40",
      iconText: "text-teal-600 dark:text-teal-400",
      hoverIconBg: "group-hover:bg-teal-500 dark:group-hover:bg-teal-500",
      hoverIconText: "group-hover:text-white",
      cardBorderHover: "hover:border-teal-300 dark:hover:border-teal-700/50",
    },
  },
  {
    name: "ลงเวลาปฏิบัติงาน",
    url: portalConfig.endpoints.attendance,
    icon: IconClockCheck,
    colorClasses: {
      iconBg: "bg-cyan-100 dark:bg-cyan-900/40",
      iconText: "text-cyan-600 dark:text-cyan-400",
      hoverIconBg: "group-hover:bg-cyan-500 dark:group-hover:bg-cyan-500",
      hoverIconText: "group-hover:text-white",
      cardBorderHover: "hover:border-cyan-300 dark:hover:border-cyan-700/50",
    },
  },
  {
    name: "ขออนุญาตใช้อาคาร",
    url: portalConfig.endpoints.facility,
    icon: IconBuilding,
    colorClasses: {
      iconBg: "bg-indigo-100 dark:bg-indigo-900/40",
      iconText: "text-indigo-600 dark:text-indigo-400",
      hoverIconBg: "group-hover:bg-indigo-500 dark:group-hover:bg-indigo-500",
      hoverIconText: "group-hover:text-white",
      cardBorderHover: "hover:border-indigo-300 dark:hover:border-indigo-700/50",
    },
  },
]

const utilityLinks: ServiceLink[] = [
  {
    name: "พิมพ์บัตรลงทะเบียนเรียน",
    url: portalConfig.endpoints.printCard,
    icon: IconPrinter,
    colorClasses: {
      iconBg: "bg-sky-100 dark:bg-sky-900/40",
      iconText: "text-sky-600 dark:text-sky-400",
      hoverIconBg: "group-hover:bg-sky-500 dark:group-hover:bg-sky-500",
      hoverIconText: "group-hover:text-white",
      cardBorderHover: "hover:border-sky-300 dark:hover:border-sky-700/50",
    },
  },
  {
    name: "ขอ QR Code เช็คชื่อ",
    url: portalConfig.endpoints.qrGuidance,
    icon: IconQrcode,
    colorClasses: {
      iconBg: "bg-fuchsia-100 dark:bg-fuchsia-900/40",
      iconText: "text-fuchsia-600 dark:text-fuchsia-400",
      hoverIconBg: "group-hover:bg-fuchsia-500 dark:group-hover:bg-fuchsia-500",
      hoverIconText: "group-hover:text-white",
      cardBorderHover: "hover:border-fuchsia-300 dark:hover:border-fuchsia-700/50",
    },
  },
  {
    name: "ไลน์ STC Link",
    url: portalConfig.endpoints.stcLink,
    image: "/landing_page_asset/stc-link-logo.webp",
    highlight: true,
  },
]
---

<Layout>
  <main class="min-h-screen bg-background text-foreground">
    <section
      class="relative overflow-hidden bg-primary py-8 text-primary-foreground md:py-16"
    >
      <div class="absolute inset-0 z-0">
        <img
          src="/landing_page_asset/100year_building.webp"
          alt="100 Year Building"
          class="h-full w-full object-cover object-center opacity-70 mix-blend-luminosity"
        />
        <div
          class="absolute inset-0 bg-linear-to-t from-primary/90 via-primary/40 to-transparent mix-blend-multiply"
        >
        </div>
      </div>
      <div
        class="absolute inset-x-0 bottom-0 z-0 h-48 bg-linear-to-t from-background via-background/55 to-transparent"
      >
      </div>
      <div
        class="absolute inset-x-0 bottom-0 z-0 h-28 bg-linear-to-t from-background/80 to-transparent blur-md"
      >
      </div>

      <div
        class="relative z-10 mx-auto grid w-full max-w-6xl gap-8 px-4 pt-16 pb-32 md:grid-cols-[minmax(0,1fr)_320px] md:px-8 md:pt-16 md:pb-32"
      >
        <div class="relative z-10 animate-fade-in-up">
          <p class="text-base font-semibold text-white/90">ยินดีต้อนรับสู่</p>
          <h1
            class="mt-1 text-4xl leading-none font-semibold tracking-normal text-white md:text-7xl"
          >
            {portalConfig.productName}
          </h1>
          <p class="mt-4 hidden max-w-xl text-lg leading-8 text-white md:block">
            {portalConfig.description}
          </p>
        </div>

        <div
          class="pointer-events-none absolute right-0 -bottom-16 z-0 animate-fade-in-up md:-bottom-16"
          style="animation-delay: 700ms;"
        >
          <img
            src={portalConfig.mascot}
            alt=""
            class="h-64 w-auto object-contain drop-shadow-2xl md:h-[26rem]"
          />
        </div>
      </div>
    </section>

    <div
      id="services"
      class="relative z-20 mx-auto w-full max-w-6xl px-4 pb-16 md:px-8"
    >
      <section class="-mt-16 grid grid-cols-2 gap-4 lg:grid-cols-4">
        {
          featuredLinks.map((link, index) => {
            const Icon = link.icon
            return (
              <a
                href={link.url}
                class={cn(
                  "group flex animate-fade-in-up flex-col gap-8 rounded-md border bg-card p-4 shadow-sm transition-all hover:shadow-md focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring",
                  link.colorClasses?.cardBorderHover
                )}
                style={`animation-delay: ${250 + index * 100}ms;`}
              >
                <div class="flex justify-between gap-4">
                  <div
                    class={cn(
                      "flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-xl transition-colors",
                      link.colorClasses?.iconBg || "bg-blue-100 dark:bg-blue-900/50",
                      link.colorClasses?.iconText || "text-primary",
                      link.colorClasses?.hoverIconBg || "group-hover:bg-primary",
                      link.colorClasses?.hoverIconText || "group-hover:text-white"
                    )}
                  >
                    {link.image ? (
                      <img
                        src={link.image}
                        alt={link.name}
                        class="h-full w-full object-cover"
                      />
                    ) : Icon ? (
                      <Icon size={28} stroke={1.7} />
                    ) : null}
                  </div>
                  <IconExternalLink
                    size={18}
                    className="text-muted-foreground/30 transition-colors group-hover:text-primary/70"
                    stroke={1.8}
                  />
                </div>
                <div>
                  <h2 class="text-lg font-semibold text-card-foreground md:text-xl">
                    {link.name}
                  </h2>
                </div>
              </a>
            )
          })
        }
      </section>

      <section class="mt-16">
        <div
          class="mb-4 flex animate-fade-in-up items-end justify-between gap-4"
          style="animation-delay: 450ms;"
        >
          <div>
            <p class="text-sm font-bold text-primary">บริการทั่วไป</p>
            <h2 class="mt-1 text-2xl font-bold">เครื่องมือเพิ่มเติม</h2>
          </div>
        </div>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {
            utilityLinks.map((link, index) => {
              const Icon = link.icon
              return (
                  <a
                    href={link.url}
                    class={cn(
                      "group relative flex animate-fade-in-up items-center gap-4 overflow-hidden rounded-lg p-4 transition-all focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring",
                      link.highlight
                        ? "border border-red-200 bg-red-50 shadow-[0_0_12px_-2px_rgba(239,68,68,0.25)] hover:border-red-300 hover:bg-red-100 hover:shadow-[0_0_12px_0px_rgba(239,68,68,0.4)] dark:border-red-900 dark:bg-red-950"
                        : cn("border bg-muted/40 hover:bg-card hover:shadow-sm", link.colorClasses?.cardBorderHover || "hover:border-border")
                    )}
                    style={`animation-delay: ${550 + index * 100}ms;`}
                  >
                    {link.highlight && (
                      <div class="pointer-events-none absolute -top-4 -right-4 z-0 h-16 w-16 animate-pulse rounded-full bg-red-200 blur-2xl transition-all duration-700 group-hover:bg-red-300 group-hover:blur-3xl dark:bg-red-900" />
                    )}
                    <div
                      class={cn(
                        "relative z-10 flex h-8 w-8 shrink-0 items-center justify-center overflow-hidden rounded-md transition-colors",
                        link.highlight
                          ? "bg-muted text-muted-foreground group-hover:bg-blue-100 group-hover:text-primary dark:group-hover:bg-blue-900/50"
                          : cn(
                              link.colorClasses?.iconBg || "bg-muted dark:bg-muted/50",
                              link.colorClasses?.iconText || "text-muted-foreground",
                              link.colorClasses?.hoverIconBg || "group-hover:bg-blue-100 dark:group-hover:bg-blue-900/50",
                              link.colorClasses?.hoverIconText || "group-hover:text-primary"
                            )
                      )}
                    >
                    {link.image ? (
                      <img
                        src={link.image}
                        alt={link.name}
                        class="h-full w-full object-cover"
                      />
                    ) : Icon ? (
                      <Icon size={22} stroke={1.7} />
                    ) : null}
                  </div>
                  <h3 class="relative z-10 flex-1 text-sm font-semibold text-card-foreground">
                    {link.name}
                  </h3>
                  <IconExternalLink
                    size={16}
                    className="relative z-10 text-muted-foreground/30 transition-colors group-hover:text-primary/70"
                    stroke={1.8}
                  />
                </a>
              )
            })
          }
        </div>
      </section>

      <section class="mt-16">
        <div
          class="mb-4 flex animate-fade-in-up items-end justify-between gap-4"
          style="animation-delay: 750ms;"
        >
          <div>
            <p class="text-sm font-bold text-muted-foreground">สำหรับบุคลากร</p>
            <h2 class="mt-1 text-2xl font-bold">ระบบงานภายใน</h2>
          </div>
        </div>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {
            staffLinks.map((link, index) => {
              const Icon = link.icon
              return (
                <a
                  href={link.url}
                  class={cn(
                    "group flex animate-fade-in-up items-center gap-4 rounded-lg border bg-muted/40 p-4 transition-all hover:bg-card hover:shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring",
                    link.colorClasses?.cardBorderHover || "hover:border-border"
                  )}
                  style={`animation-delay: ${850 + index * 100}ms;`}
                >
                  <div
                    class={cn(
                      "flex h-8 w-8 shrink-0 items-center justify-center overflow-hidden rounded-md transition-colors",
                      link.colorClasses?.iconBg || "bg-muted dark:bg-muted/50",
                      link.colorClasses?.iconText || "text-muted-foreground",
                      link.colorClasses?.hoverIconBg || "group-hover:bg-blue-100 dark:group-hover:bg-blue-900/50",
                      link.colorClasses?.hoverIconText || "group-hover:text-primary"
                    )}
                  >
                    {link.image ? (
                      <img
                        src={link.image}
                        alt={link.name}
                        class="h-full w-full object-cover"
                      />
                    ) : Icon ? (
                      <Icon size={22} stroke={1.7} />
                    ) : null}
                  </div>
                  <h3 class="flex-1 text-sm font-semibold text-card-foreground">
                    {link.name}
                  </h3>
                  <IconExternalLink
                    size={16}
                    className="text-muted-foreground/30 transition-colors group-hover:text-primary/70"
                    stroke={1.8}
                  />
                </a>
              )
            })
          }
        </div>
      </section>
    </div>
  </main>
</Layout>
